---
import Base from "../layouts/Base.astro";
import Timeline from "./Timeline.astro";
import Footer from "./Footer.astro";
import { parsePulseLog, getArchiveMonths } from "../lib/parse-pulse.js";
import { getStrings, getAllLanguageOptions } from "../lib/i18n.js";

interface Props {
  locale: string;
  month: string;
}

const { locale, month } = Astro.props;
const t = getStrings(locale);
const languageOptions = getAllLanguageOptions();

const items = parsePulseLog().filter((item) => item.month === month);
const months = getArchiveMonths();
const monthIndex = months.indexOf(month);
// months is newest-first: "previous" month in time sits at a higher index.
const prevMonth = monthIndex < months.length - 1 ? months[monthIndex + 1] : null;
const nextMonth = monthIndex > 0 ? months[monthIndex - 1] : null;

const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const archivePath = `archive/${month}/`;

function localeUrl(loc: string, path: string = archivePath): string {
  const prefix = loc === "en" ? "" : `${loc}/`;
  return `${normalizedBase}${prefix}${path}`;
}
const homeUrl = localeUrl(locale, "");

const title = t.archiveTitle.replace("{month}", month);
const description = t.archiveDescription.replace("{month}", month);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: title,
  numberOfItems: items.length,
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "NewsArticle",
      headline: (item.summaries?.[locale] || item.summary).slice(0, 110),
      datePublished: item.datetimeUtc,
      url: item.url,
      inLanguage: t.htmlLang,
    },
  })),
};
---

<Base
  title={title}
  description={description}
  htmlLang={t.htmlLang}
  locale={locale}
  path={archivePath}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="header">
    <div class="header-inner">
      <p class="site-name"><a href={homeUrl}>{t.title}</a></p>
      <h1>{t.archiveLabel} — {month}</h1>
      <nav class="lang-nav" aria-label={t.languageLabel}>
        {
          languageOptions.map((opt) =>
            opt.key === locale ? (
              <span class="lang-pill lang-active">{opt.name}</span>
            ) : (
              <a class="lang-pill" href={localeUrl(opt.key)}>
                {opt.name}
              </a>
            ),
          )
        }
      </nav>
    </div>
    <div class="header-line"></div>
  </header>

  <main class="main">
    <nav class="month-nav" aria-label={t.browseArchive}>
      {
        prevMonth ? (
          <a class="month-link" href={localeUrl(locale, `archive/${prevMonth}/`)}>
            ← {prevMonth}
          </a>
        ) : (
          <span />
        )
      }
      <a class="month-link month-home" href={homeUrl}>{t.backHome}</a>
      {
        nextMonth ? (
          <a class="month-link" href={localeUrl(locale, `archive/${nextMonth}/`)}>
            {nextMonth} →
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <div class="search-row">
      <input
        id="archive-search"
        class="search-input"
        type="search"
        placeholder={t.searchPlaceholder}
        aria-label={t.filterSearch}
      />
    </div>

    <Timeline items={items} locale={locale} t={t} />

    <p class="empty-state" id="empty" style="display: none;">
      {t.empty}
    </p>

    <Footer t={t} />
  </main>
</Base>

<script is:inline>
  (function archiveSearch() {
    const input = document.getElementById("archive-search");
    if (!input) return;
    const cards = [...document.querySelectorAll(".card")];
    const separators = [...document.querySelectorAll(".day-separator")];
    const emptyEl = document.getElementById("empty");
    const cardTexts = new Map(
      cards.map((card) => [card, card.textContent.toLowerCase()]),
    );

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      const visibleDates = new Set();
      let visibleCount = 0;

      cards.forEach((card) => {
        const visible = !query || cardTexts.get(card).includes(query);
        card.style.display = visible ? "" : "none";
        if (visible) {
          visibleCount++;
          visibleDates.add(card.dataset.displayDate);
        }
      });

      separators.forEach((sep) => {
        sep.style.display = visibleDates.has(sep.dataset.date) ? "" : "none";
      });

      if (emptyEl) emptyEl.style.display = visibleCount === 0 ? "" : "none";
    });
  })();
</script>

<style>
  .header {
    padding: 3rem 1rem 0;
  }

  .header-inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .site-name {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.375rem;
  }

  .site-name a {
    color: inherit;
  }

  .site-name a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .lang-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .lang-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    text-decoration: none;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  a.lang-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .lang-active {
    color: var(--accent);
    border-color: var(--accent);
    font-weight: 600;
  }

  .header-line {
    max-width: 48rem;
    margin: 2rem auto 0;
    height: 1px;
    background: var(--border);
    position: relative;
  }

  .header-line::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    width: 3rem;
    height: 1px;
    background: var(--accent);
  }

  .main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  .month-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .month-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .month-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .search-row {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .search-input {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    padding: 0.25rem 0.625rem;
    width: 14rem;
    max-width: 100%;
    transition: border-color 0.15s;
  }

  .search-input::placeholder {
    color: var(--text-tertiary);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .empty-state {
    text-align: center;
    color: var(--text-tertiary);
    padding: 3rem 0;
    font-family: var(--font-body);
  }

  @media (max-width: 640px) {
    .header {
      padding-top: 2rem;
    }

    .header h1 {
      font-size: 1.375rem;
    }
  }
</style>
