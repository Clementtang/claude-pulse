---
import Base from "../layouts/Base.astro";
import Timeline from "./Timeline.astro";
import Footer from "./Footer.astro";
import {
  parsePulseLog,
  getCategories,
  getArchiveMonths,
  toDisplayDate,
} from "../lib/parse-pulse.js";
import {
  getStrings,
  getAllLanguageOptions,
  SUPPORTED_LOCALES,
} from "../lib/i18n.js";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getStrings(locale);
const languageOptions = getAllLanguageOptions();

const allItems = parsePulseLog(); // already sorted desc by datetimeUtc
// Home shows the last 30 days; everything older lives on archive pages.
// Keeps page weight bounded as the log grows (~900 KB → ~150 KB HTML).
const cutoff = toDisplayDate(
  new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString(),
);
const items = allItems.filter((item) => item.displayDate >= cutoff);
const months = getArchiveMonths(allItems);
const categories = getCategories();

const base = import.meta.env.BASE_URL;

// Build language URLs — each locale points to its own index page
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
function localeUrl(loc: string): string {
  return loc === "en" ? normalizedBase : `${normalizedBase}${loc}/`;
}

function archiveUrl(month: string): string {
  return `${localeUrl(locale)}archive/${month}/`;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: t.seoTitle || t.title,
  numberOfItems: items.length,
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "NewsArticle",
      headline: (item.summaries?.[locale] || item.summary).slice(0, 110),
      datePublished: item.datetimeUtc,
      url: item.url,
      inLanguage: t.htmlLang,
    },
  })),
};
---

<Base
  title={t.seoTitle || t.title}
  description={t.metaDescription}
  htmlLang={t.htmlLang}
  locale={locale}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <header class="header">
    <div class="header-inner">
      <h1>
        <svg class="logo" width="36" height="20" viewBox="0 0 36 20" fill="none" aria-hidden="true">
          <polyline
            points="0,10 6,10 9,10 12,3 15,17 18,6 21,14 24,10 28,10 36,10"
            stroke="var(--accent)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
        {t.title}
      </h1>
      <p class="subtitle">{t.subtitle}</p>
      <nav class="lang-nav" aria-label={t.languageLabel}>
        {
          languageOptions.map((opt) =>
            opt.key === locale ? (
              <span class="lang-pill lang-active">{opt.name}</span>
            ) : (
              <a class="lang-pill" href={localeUrl(opt.key)}>
                {opt.name}
              </a>
            ),
          )
        }
      </nav>
      <div class="header-meta">
        <a
          id="status-link"
          class="status-link"
          href="https://status.claude.com"
          target="_blank"
          rel="noopener noreferrer"
          title="Claude Service Status"
        >
          <span class="status-dot" data-indicator="loading"></span>
          <span class="status-text">{t.statusLoading}</span>
          <span class="external-icon" aria-hidden="true">&#8599;</span>
        </a>
        <a href={`${base}feed.xml`} class="rss-link" title="RSS Feed">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="6.18" cy="17.82" r="2.18"></circle>
            <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"
            ></path>
          </svg>
          {t.rss}
        </a>
      </div>
    </div>
    <div class="header-line"></div>
  </header>

  <main class="main">
    <nav class="filters" id="filters">
      <div class="filter-group">
        <span class="filter-label">{t.filterCategory}</span>
        <button class="filter-btn active" data-category="all">
          {t.filterAll}
        </button>
        {
          categories.map((cat) => (
            <button
              class="filter-btn"
              data-category={cat.key}
              style={`--cat-color: ${cat.color}`}
            >
              <span class="cat-dot" style={`background: ${cat.color}`} />
              {t.categories[cat.key] || cat.label}
            </button>
          ))
        }
      </div>
      <div class="filter-group">
        <span class="filter-label">{t.filterTime}</span>
        <button class="filter-btn range-btn active" data-range="7">
          {t.range7}
        </button>
        <button class="filter-btn range-btn" data-range="30">
          {t.range30}
        </button>
        <a class="filter-btn archive-link" href={archiveUrl(months[0])}>
          {t.archiveLabel} ↗
        </a>
      </div>
    </nav>

    <Timeline items={items} locale={locale} t={t} />

    <p class="empty-state" id="empty" style="display: none;">
      {t.empty}
    </p>

    <nav class="archive-nav" aria-label={t.browseArchive}>
      <span class="archive-nav-label">{t.browseArchive}</span>
      {
        months.map((month) => (
          <a class="archive-month" href={archiveUrl(month)}>
            {month}
          </a>
        ))
      }
    </nav>

    <Footer t={t} />
  </main>
</Base>

<script
  is:inline
  define:vars={{
    CURRENT_LOCALE: locale,
    SUPPORTED_LOCALES,
    RELATIVE_STRINGS: t.relative,
    STATUS_OK_DEFAULT: t.statusOk,
    WEEKDAY_FORMAT: t.weekdayFormat,
    BASE_PATH: normalizedBase,
  }}
>
  // ============================================================
  // Auto-detect language on first visit (runs inline, before body)
  // ============================================================
  (function autoDetectLocale() {
    try {
      // Never redirect crawlers. A JS locale redirect makes Googlebot (which
      // presents as en) treat /ja/, /ko/, etc. as "Page with redirect" and drop
      // them from the index — bots must render each locale page as-is.
      if (/bot|crawl|spider|slurp/i.test(navigator.userAgent || "")) return;

      if (localStorage.getItem("claude-pulse-lang-redirected")) return;

      const browserLang = navigator.language || "en";

      // Exact match
      let matched = SUPPORTED_LOCALES.find((l) => l === browserLang);

      // Prefix match (e.g., "zh-Hant-TW" → "zh-TW" via "zh-TW" prefix check)
      if (!matched) {
        matched = SUPPORTED_LOCALES.find((l) => browserLang.startsWith(l));
      }

      // Primary tag fallback
      if (!matched) {
        const primary = browserLang.split("-")[0].toLowerCase();
        if (primary === "zh") {
          // Try region hint — HK/MO/TW all map to zh-TW
          if (/-(CN|SG)/i.test(browserLang)) matched = "zh-CN";
          else matched = "zh-TW";
        } else if (primary === "ja") matched = "ja";
        else if (primary === "ko") matched = "ko";
        else matched = "en";
      }

      localStorage.setItem("claude-pulse-lang-redirected", "1");

      if (matched && matched !== CURRENT_LOCALE) {
        const target =
          matched === "en" ? BASE_PATH : BASE_PATH + matched + "/";
        window.location.replace(target);
      }
    } catch (e) {
      // localStorage/navigator unavailable — skip
    }
  })();

  // ============================================================
  // Language switcher — handled via plain <a> links, no JS needed
  // ============================================================

  // ============================================================
  // Status monitoring — status.claude.com
  // ============================================================
  async function loadStatus() {
    const link = document.getElementById("status-link");
    if (!link) return;

    const dot = link.querySelector(".status-dot");
    const text = link.querySelector(".status-text");
    if (!dot || !text) return;

    try {
      const [statusRes, incidentsRes] = await Promise.all([
        fetch("https://status.claude.com/api/v2/status.json"),
        fetch("https://status.claude.com/api/v2/incidents/unresolved.json"),
      ]);

      if (!statusRes.ok || !incidentsRes.ok) {
        throw new Error("Status API unavailable");
      }

      const statusData = await statusRes.json();
      const incidentsData = await incidentsRes.json();

      const indicator = (statusData.status && statusData.status.indicator) || "none";
      const apiDescription = statusData.status && statusData.status.description;
      const firstIncident = incidentsData.incidents && incidentsData.incidents[0];

      dot.setAttribute("data-indicator", indicator);
      // Prefer: unresolved incident name → localized default → API description
      text.textContent =
        (firstIncident && firstIncident.name) ||
        (indicator === "none" ? STATUS_OK_DEFAULT : apiDescription) ||
        STATUS_OK_DEFAULT;

      link.classList.add("ready");
    } catch (e) {
      link.style.display = "none";
    }
  }

  loadStatus();

  // ============================================================
  // Time formatting — browser timezone + relative time
  // ============================================================
  const TZ =
    Intl.DateTimeFormat().resolvedOptions().timeZone || "Asia/Taipei";

  // Use en-CA to get stable YYYY-MM-DD HH:mm numeric parts regardless of locale
  const ymdhmFormatter = new Intl.DateTimeFormat("en-CA", {
    timeZone: TZ,
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  });

  function formatYmdHm(d) {
    const parts = ymdhmFormatter.formatToParts(d);
    const get = (type) => {
      const p = parts.find((x) => x.type === type);
      return p ? p.value : "";
    };
    return (
      get("year") +
      "-" +
      get("month") +
      "-" +
      get("day") +
      " " +
      get("hour") +
      ":" +
      get("minute")
    );
  }

  function formatYmd(d) {
    const parts = ymdhmFormatter.formatToParts(d);
    const get = (type) => {
      const p = parts.find((x) => x.type === type);
      return p ? p.value : "";
    };
    return get("year") + "-" + get("month") + "-" + get("day");
  }

  // Weekday formatter uses the current locale so output matches page language.
  // Pin to Hanoi to match server-side displayDate grouping (avoids viewer-TZ
  // weekday drift when the noon-UTC anchor crosses days in their local zone).
  const weekdayFormatter = new Intl.DateTimeFormat(CURRENT_LOCALE, {
    timeZone: "Asia/Ho_Chi_Minh",
    weekday: WEEKDAY_FORMAT || "long",
  });

  function interp(tmpl, n) {
    return tmpl.replace("{n}", String(n));
  }

  function formatRelative(iso) {
    const d = new Date(iso);
    const diffSec = Math.floor((Date.now() - d.getTime()) / 1000);
    if (diffSec < 60) return RELATIVE_STRINGS.justNow;
    if (diffSec < 3600)
      return interp(RELATIVE_STRINGS.minutesAgo, Math.floor(diffSec / 60));
    if (diffSec < 86400)
      return interp(RELATIVE_STRINGS.hoursAgo, Math.floor(diffSec / 3600));
    const days = Math.floor(diffSec / 86400);
    if (days < 30) return interp(RELATIVE_STRINGS.daysAgo, days);
    const months = Math.floor(days / 30);
    if (months < 12) return interp(RELATIVE_STRINGS.monthsAgo, months);
    return interp(RELATIVE_STRINGS.yearsAgo, Math.floor(days / 365));
  }

  // Format card time text — "2026-04-08 15:00 · 3 days ago"
  document.querySelectorAll(".card-time[data-datetime]").forEach((el) => {
    const iso = el.dataset.datetime;
    const d = new Date(iso);
    const abs = formatYmdHm(d);
    const rel = formatRelative(iso);
    el.textContent = abs + " · " + rel;
  });

  // Format day separator chip — "2026-04-08 Wednesday"
  // dateStr is already the Hanoi display date (server-rendered); show as-is and
  // derive weekday from a noon-UTC anchor to be safe against viewer-TZ drift.
  document.querySelectorAll(".day-separator-chip").forEach((el) => {
    const dateStr = el.getAttribute("datetime");
    if (!dateStr) return;
    const d = new Date(dateStr + "T12:00:00Z");
    const weekday = weekdayFormatter.format(d);
    el.textContent = dateStr + " " + weekday;
  });

  // ============================================================
  // Filters — category + time range
  // ============================================================
  const categoryBtns = document.querySelectorAll("[data-category]");
  const rangeBtns = document.querySelectorAll("[data-range]");
  const cards = document.querySelectorAll(".card");
  const separators = document.querySelectorAll(".day-separator");
  const emptyEl = document.getElementById("empty");

  let activeCategory = "all";
  let activeRange = "7";

  function daysSince(iso) {
    const d = new Date(iso);
    return Math.floor((Date.now() - d.getTime()) / 86400000);
  }

  function applyFilters() {
    let visibleCount = 0;
    const visibleDates = new Set();

    cards.forEach((card) => {
      const cat = card.dataset.category;
      const iso = card.dataset.datetime;
      const days = daysSince(iso);

      const matchCategory =
        activeCategory === "all" || cat === activeCategory;
      const matchRange =
        activeRange === "all" || days <= parseInt(activeRange, 10);
      const visible = matchCategory && matchRange;

      card.style.display = visible ? "" : "none";
      if (visible) {
        visibleCount++;
        visibleDates.add(card.dataset.displayDate);
      }
    });

    separators.forEach((sep) => {
      const date = sep.dataset.date;
      sep.style.display = visibleDates.has(date) ? "" : "none";
    });

    if (emptyEl) {
      emptyEl.style.display = visibleCount === 0 ? "" : "none";
    }
  }

  categoryBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      categoryBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");
      activeCategory = btn.dataset.category;
      applyFilters();
    });
  });

  rangeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      rangeBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");
      activeRange = btn.dataset.range;
      applyFilters();
    });
  });

  applyFilters();
</script>

<style>
  /* ============================================================
     HEADER — Editorial masthead
     ============================================================ */
  .header {
    padding: 3rem 1rem 0;
  }

  .header-inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .header h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 0.375rem;
  }

  .header-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .rss-link,
  .status-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .rss-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  /* ============================================================
     STATUS INDICATOR
     ============================================================ */
  .status-link {
    max-width: 18rem;
    overflow: hidden;
  }

  .status-link .status-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-link:hover {
    border-color: var(--border-hover);
    color: var(--text-secondary);
    text-decoration: none;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-tertiary);
    flex-shrink: 0;
    position: relative;
  }

  .status-dot[data-indicator="none"] {
    background: #10b981;
  }
  .status-dot[data-indicator="minor"] {
    background: #f59e0b;
  }
  .status-dot[data-indicator="major"],
  .status-dot[data-indicator="critical"] {
    background: #dc2626;
  }
  .status-dot[data-indicator="maintenance"] {
    background: #2563eb;
  }

  .status-dot[data-indicator="minor"]::before,
  .status-dot[data-indicator="major"]::before,
  .status-dot[data-indicator="critical"]::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 1px solid currentColor;
    color: inherit;
    animation: status-pulse 2s ease-out infinite;
  }

  @keyframes status-pulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  .status-link.ready .status-text {
    color: inherit;
  }

  .external-icon {
    font-size: 0.75rem;
    line-height: 1;
    opacity: 0.7;
  }

  /* ============================================================
     LOGO
     ============================================================ */
  .logo {
    vertical-align: middle;
    margin-right: 0.375rem;
    position: relative;
    top: -1px;
  }

  /* ============================================================
     LANGUAGE NAV — pill buttons matching status/RSS style
     ============================================================ */
  .lang-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .lang-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    text-decoration: none;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  a.lang-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .lang-active {
    color: var(--accent);
    border-color: var(--accent);
    font-weight: 600;
  }

  .header-line {
    max-width: 48rem;
    margin: 2.5rem auto 0;
    height: 1px;
    background: var(--border);
    position: relative;
  }

  .header-line::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    width: 3rem;
    height: 1px;
    background: var(--accent);
  }

  /* ============================================================
     MAIN / FILTERS
     ============================================================ */
  .main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 3rem;
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .filter-group {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .filter-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-right: 0.75rem;
  }

  .filter-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.25rem 0.25rem;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .filter-btn:hover {
    color: var(--text);
  }

  .filter-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .filter-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .filter-btn .cat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ============================================================
     EMPTY STATE + ARCHIVE NAV
     ============================================================ */
  .empty-state {
    text-align: center;
    color: var(--text-tertiary);
    padding: 3rem 0;
    font-family: var(--font-body);
  }

  .archive-link {
    text-decoration: none;
  }

  .archive-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .archive-nav-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-right: 0.75rem;
  }

  .archive-month {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    text-decoration: none;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .archive-month:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 640px) {
    .header {
      padding-top: 2rem;
    }

    .header h1 {
      font-size: 1.625rem;
    }

    .subtitle {
      font-size: 0.8125rem;
    }

    .header-line {
      margin-top: 1.75rem;
    }

    .main {
      padding: 2rem 1rem 2rem;
    }

    .filter-label {
      width: 100%;
      margin-bottom: 0.25rem;
    }
  }
</style>
