---
interface Props {
  title?: string;
  description?: string;
  htmlLang?: string;
  locale?: string;
}

const {
  title = "Claude Pulse",
  description = "Anthropic / Claude news tracker",
  htmlLang = "en",
  locale = "en",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={htmlLang} data-locale={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Source+Sans+3:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Noto+Sans+TC:wght@400;500&family=Noto+Sans+SC:wght@400;500&family=Noto+Sans+JP:wght@400;500&family=Noto+Sans+KR:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Claude Pulse RSS"
      href={`${base}feed.xml`}
    />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-R69N8EZQE7"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R69N8EZQE7');
    </script>
    <style is:global>
      :root {
        /* Backgrounds — warm cream */
        --bg: #faf9f0;
        --bg-surface: #f5f3e8;
        --bg-surface-hover: #efede0;

        /* Text hierarchy — deep warm neutrals */
        --text: #1a1a1b;
        --text-secondary: #5c5a52;
        --text-tertiary: #9c9889;

        /* Accent — Anthropic terracotta */
        --accent: #d97757;
        --accent-light: #e8956f;

        /* Borders — warm gray */
        --border: #e5e2d6;
        --border-hover: #d4d0c2;

        /* Font stacks — English base */
        --font-display: "Newsreader", "Noto Sans TC", Georgia, serif;
        --font-body: "Source Sans 3", "Noto Sans TC", system-ui, sans-serif;
        --font-mono: "IBM Plex Mono", ui-monospace, monospace;

        /* Spacing tokens */
        --sp-1: 0.5rem;
        --sp-2: 1rem;
        --sp-3: 1.5rem;
        --sp-4: 2rem;
        --sp-6: 3rem;
        --sp-8: 4rem;
      }

      /* Per-locale CJK primary font */
      html[data-locale="zh-TW"] {
        --font-body: "Noto Sans TC", "Source Sans 3", system-ui, sans-serif;
        --font-display: "Newsreader", "Noto Sans TC", Georgia, serif;
      }
      html[data-locale="zh-CN"] {
        --font-body: "Noto Sans SC", "Source Sans 3", system-ui, sans-serif;
        --font-display: "Newsreader", "Noto Sans SC", Georgia, serif;
      }
      html[data-locale="ja"] {
        --font-body: "Noto Sans JP", "Source Sans 3", system-ui, sans-serif;
        --font-display: "Newsreader", "Noto Sans JP", Georgia, serif;
      }
      html[data-locale="ko"] {
        --font-body: "Noto Sans KR", "Source Sans 3", system-ui, sans-serif;
        --font-display: "Newsreader", "Noto Sans KR", Georgia, serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s;
      }

      a:hover {
        color: var(--accent-light);
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
