---
import Base from "../layouts/Base.astro";
import { parsePulseLog, getCategories } from "../lib/parse-pulse.js";

const items = parsePulseLog();
const categories = getCategories();

// Group items by date
const grouped = new Map();
for (const item of items) {
  if (!grouped.has(item.date)) {
    grouped.set(item.date, []);
  }
  grouped.get(item.date).push(item);
}

const base = import.meta.env.BASE_URL;
---

<Base>
  <header class="header">
    <div class="header-inner">
      <div class="header-title">
        <h1>Claude Pulse</h1>
        <p class="subtitle">Anthropic / Claude 動態追蹤</p>
      </div>
      <a href={`${base}feed.xml`} class="rss-link" title="RSS Feed">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="6.18" cy="17.82" r="2.18"></circle>
          <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"></path>
        </svg>
        RSS
      </a>
    </div>
  </header>

  <main class="main">
    <nav class="filters" id="filters">
      <div class="filter-group">
        <span class="filter-label">分類</span>
        <button class="category-btn active" data-category="all">全部</button>
        {categories.map((cat) => (
          <button
            class="category-btn"
            data-category={cat.key}
            style={`--cat-color: ${cat.color}`}
          >
            <span class="cat-dot" style={`background: ${cat.color}`}></span>
            {cat.label}
          </button>
        ))}
      </div>
      <div class="filter-group">
        <span class="filter-label">時間</span>
        <button class="range-btn active" data-range="7">7 天</button>
        <button class="range-btn" data-range="30">30 天</button>
        <button class="range-btn" data-range="all">全部</button>
      </div>
    </nav>

    <div class="timeline" id="timeline">
      {[...grouped.entries()].map(([date, dateItems]) => (
        <section class="date-group" data-date={date}>
          <h2 class="date-heading">{date}</h2>
          <div class="cards">
            {dateItems.map((item) => (
              <article class="card" data-category={item.category}>
                <span
                  class="card-category"
                  style={`background: ${item.categoryColor}22; color: ${item.categoryColor}; border-color: ${item.categoryColor}44`}
                >
                  {item.categoryLabel}
                </span>
                <p class="card-summary">{item.summary}</p>
                <span class="card-source">{item.source}</span>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <p class="empty-state" id="empty" style="display: none;">
      沒有符合條件的項目
    </p>

    <footer class="footer">
      <p>
        Claude Pulse by <a href="https://github.com/Clementtang">Clement Tang</a>
      </p>
    </footer>
  </main>
</Base>

<script>
  const categoryBtns = document.querySelectorAll<HTMLButtonElement>(".category-btn");
  const rangeBtns = document.querySelectorAll<HTMLButtonElement>(".range-btn");
  const dateGroups = document.querySelectorAll<HTMLElement>(".date-group");
  const emptyEl = document.getElementById("empty")!;

  let activeCategory = "all";
  let activeRange = "7";

  function daysBetween(dateStr: string): number {
    const d = new Date(dateStr + "T00:00:00");
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    return Math.floor((now.getTime() - d.getTime()) / 86400000);
  }

  function applyFilters() {
    let visibleCount = 0;

    dateGroups.forEach((group) => {
      const date = group.dataset.date!;
      const days = daysBetween(date);
      const inRange = activeRange === "all" || days <= parseInt(activeRange);

      if (!inRange) {
        group.style.display = "none";
        return;
      }

      const cards = group.querySelectorAll<HTMLElement>(".card");
      let groupVisible = 0;

      cards.forEach((card) => {
        const cat = card.dataset.category!;
        const show = activeCategory === "all" || cat === activeCategory;
        card.style.display = show ? "" : "none";
        if (show) groupVisible++;
      });

      group.style.display = groupVisible > 0 ? "" : "none";
      visibleCount += groupVisible;
    });

    emptyEl.style.display = visibleCount === 0 ? "" : "none";
  }

  categoryBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      categoryBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeCategory = btn.dataset.category!;
      applyFilters();
    });
  });

  rangeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      rangeBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeRange = btn.dataset.range!;
      applyFilters();
    });
  });

  applyFilters();
</script>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 1rem;
  }

  .header-inner {
    max-width: 48rem;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-title h1 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-top: 0.125rem;
  }

  .rss-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--text-muted);
    font-size: 0.8125rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    transition: color 0.15s, border-color 0.15s;
  }

  .rss-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-label {
    color: var(--text-dim);
    font-size: 0.75rem;
    min-width: 2.5rem;
  }

  .category-btn,
  .range-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 0.25rem 0.625rem;
    border-radius: 1rem;
    font-size: 0.8125rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .category-btn:hover,
  .range-btn:hover {
    color: var(--text);
    border-color: var(--text-dim);
  }

  .category-btn.active {
    background: var(--cat-color, var(--accent));
    color: #fff;
    border-color: transparent;
  }

  .category-btn.active[data-category="all"] {
    background: var(--accent);
  }

  .range-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: transparent;
  }

  .cat-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .date-heading {
    font-size: 0.875rem;
    color: var(--text-dim);
    font-weight: 500;
    margin-bottom: 0.75rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }

  .date-group + .date-group {
    margin-top: 1.5rem;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.875rem 1rem;
    transition: background 0.15s;
  }

  .card:hover {
    background: var(--bg-card-hover);
  }

  .card-category {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
    border: 1px solid;
    margin-bottom: 0.5rem;
  }

  .card-summary {
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .card-source {
    display: block;
    margin-top: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .empty-state {
    text-align: center;
    color: var(--text-dim);
    padding: 3rem 0;
  }

  .footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  @media (max-width: 640px) {
    .header-title h1 {
      font-size: 1.25rem;
    }

    .card {
      padding: 0.75rem;
    }

    .card-summary {
      font-size: 0.875rem;
    }
  }
</style>
